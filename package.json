{
  "name": "@citadel-app/sdk",
  "version": "1.1.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/citadel-app/citadel-plugin-sdk.git"
  },
  "description": "Public Plugin SDK for Citadel Workspace",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && vite build"
  },
  "dependencies": {
    "@citadel-app/core": "1.1.3"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vite": "^7.2.6"
  }
}
